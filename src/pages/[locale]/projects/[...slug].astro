---
import { getProjectPaths, getProjectVersions } from '@/utils/docs';
import ProjectRouter from '@/components/pages/ProjectRouter.astro';
import type { Locale } from '@/i18n';

export async function getStaticPaths() {
  const locales = ['en-us','ja-jp','ko-kr','ar-sa','es-es','fr-fr','pt-pt','ru-ru','de-de'] as Locale[];
  const projectPaths = await getProjectPaths('');
  const paths = [];
  for (const l of locales) {
    for (const p of projectPaths) {
      paths.push({ params: { locale: l, slug: p.params.slug } });
    }
  }
  return paths;
}

const { slug } = Astro.params;
const locale = Astro.currentLocale! as Locale;
const parts = slug!.split('/');
const projectSlug = parts[0];

// 检测是否为最新版本路径，生成重定向
const VERSION_RE = /^(v\d+|alpha|beta)$/i;
if (parts.length >= 2 && VERSION_RE.test(parts[1])) {
  const verDir = parts[1].toLowerCase();
  const versionInfo = await getProjectVersions(projectSlug);
  const currentVersion = versionInfo?.currentVersion?.toLowerCase();
  const latestDir = currentVersion === 'alpha' ? 'alpha' : currentVersion === 'beta' ? 'beta' : currentVersion ? `v${currentVersion.replace(/\./, '')}` : '';

  if (verDir === latestDir) {
    const rest = parts.slice(2).join('/');
    const prefix = `/${locale}`;
    const target = rest ? `${prefix}/projects/${projectSlug}/${rest}/` : `${prefix}/projects/${projectSlug}/`;
    return Astro.redirect(target, 301);
  }
}
---
<ProjectRouter slug={slug!} locale={locale} />
