---
import { getProjectPaths } from '@/utils/docs';
import ProjectRouter from '@/components/pages/ProjectRouter.astro';
import type { Locale } from '@/i18n';

export async function getStaticPaths() {
  const locales = ['en-us','ja-jp','ko-kr','ar-sa','es-es','fr-fr','pt-pt','ru-ru','de-de'] as Locale[];
  const projectPaths = await getProjectPaths('');
  const paths = [];
  for (const locale of locales) {
    for (const p of projectPaths) {
      paths.push({ params: { locale, slug: p.params.slug } });
    }
  }
  return paths;
}

const { slug } = Astro.params;
const locale = Astro.currentLocale! as Locale;
---
<ProjectRouter slug={slug!} locale={locale} />
