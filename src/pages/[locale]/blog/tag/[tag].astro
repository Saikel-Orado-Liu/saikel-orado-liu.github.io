---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import BlogTag from '../../../../components/pages/BlogTag.astro';
import { useTranslations } from '../../../../i18n';
import type { Locale } from '../../../../i18n';
import { getAllTags as getTags } from '../../../../utils/content';

const locale = Astro.currentLocale! as Locale;
const t = useTranslations(locale);

export async function getStaticPaths() {
  const locales = ['en-us','ja-jp','ko-kr','ar-sa','es-es','fr-fr','pt-pt','ru-ru','de-de'];
  const paths = [];
  for (const locale of locales) {
    const tags = await getTags(locale);
    for (const [tag] of tags) {
      paths.push({ params: { locale, tag } });
    }
  }
  return paths;
}

const { tag } = Astro.params;
---

<BaseLayout title={`#${tag} — ${t('blog-title')}`} locale={locale}>
  <BlogTag locale={locale} tag={tag!} />
</BaseLayout>
