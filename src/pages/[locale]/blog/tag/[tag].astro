---
import BlogTagRoute from '@/components/route/BlogTagRoute.astro';
import { getAllTags as getTags } from '@/utils/content';

export async function getStaticPaths() {
  const locales = ['en-us','ja-jp','ko-kr','ar-sa','es-es','fr-fr','pt-pt','ru-ru','de-de'];
  const paths = [];
  for (const l of locales) {
    const tags = await getTags(l);
    for (const [tag] of tags) {
      paths.push({ params: { locale: l, tag }, props: { tag } });
    }
  }
  return paths;
}

const locale = Astro.currentLocale!;
const { tag } = Astro.props;
---
<BlogTagRoute locale={locale} tag={tag} />
