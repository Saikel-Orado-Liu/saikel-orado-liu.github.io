---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import BlogTag from '../../../../components/pages/BlogTag.astro';
import { useTranslations } from '../../../../i18n';
import type { Locale } from '../../../../i18n';
import { getAllTags } from '../../../../utils/content';

const locale = (Astro.currentLocale || 'pt-pt') as Locale;
const t = useTranslations(locale);

export async function getStaticPaths() {
  const tags = await getAllTags('pt-pt');
  return tags.map(([tag]) => ({ params: { tag } }));
}

const { tag } = Astro.params;
---

<BaseLayout title={`#${tag} — ${t('blog-title')}`} locale={locale}>
  <BlogTag locale={locale as Locale} tag={tag!} />
</BaseLayout>
