---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModulePage from '../../components/pages/ModulePage.astro';
import { useTranslations } from '../../i18n';
import type { Locale } from '../../i18n';

const locale = Astro.currentLocale! as Locale;
const t = useTranslations(locale);
---

<BaseLayout title={t('game-title')} description={t('game-description')} locale={locale}>
  <ModulePage locale={locale} module="game" icon="bx-joystick" />
</BaseLayout>
