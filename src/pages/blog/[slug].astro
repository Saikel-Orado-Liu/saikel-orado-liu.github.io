---
import { getCollection, render } from 'astro:content';
import BlogLayout from '@/layouts/BlogLayout.astro';
import { useTranslations } from '@/i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '@/i18n';

const locale = Astro.currentLocale! as Locale;
const t = useTranslations(locale);

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.locale === 'zh-cn');
  return posts.map(post => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BlogLayout title={post.data.title} seoTitle={`${post.data.title} — ${t('blog-title')} | ${t('site-title')}`} description={post.data.excerpt} seoDescription={post.data.excerpt} locale={locale} date={post.data.date} tags={post.data.tags} categories={post.data.categories} image={post.data.image}>
  <div class="mb-8">
    <a href={getRelativeLocaleUrl(locale, '/blog/')} class="back-link"><i class="bx bx-left-arrow-alt"></i> {t('blog-back')}</a>
  </div>
  <Content />
</BlogLayout>
