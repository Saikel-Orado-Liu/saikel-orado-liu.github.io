---
import BlogTagRoute from '@/components/route/BlogTagRoute.astro';
import { getAllTags as getTags } from '@/utils/content';

export async function getStaticPaths() {
  const tags = await getTags('zh-cn');
  return tags.map(([tag]) => ({ params: { tag }, props: { tag } }));
}

const locale = Astro.currentLocale!;
const { tag } = Astro.props;
---
<BlogTagRoute locale={locale} tag={tag} />
