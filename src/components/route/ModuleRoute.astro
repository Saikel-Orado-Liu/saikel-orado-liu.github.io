---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ModulePage from '@/components/pages/ModulePage.astro';
import { useTranslations } from '@/i18n';
import { getLocalizedPlugins } from '@/utils/content';
import type { Locale } from '@/i18n';

export interface Props {
  locale: string;
  module: 'ai' | 'game' | 'ue5';
  icon: string;
  titleKey: string;
  descKey: string;
  seoDescKey: string;
  imageKey: string;
}

const { locale, module, icon, titleKey, descKey, seoDescKey, imageKey } = Astro.props;
const t = useTranslations(locale as Locale);
const plugins = module === 'ue5' ? await getLocalizedPlugins(locale) : undefined;
---

<BaseLayout title={`${t(titleKey)} — ${t('site-title')}`} description={t(descKey)} seoDescription={t(seoDescKey)} ogImage={`/${imageKey}.png`} locale={locale as Locale}>
  <ModulePage locale={locale as Locale} module={module} icon={icon} {...(plugins ? { plugins } : {})} />
</BaseLayout>
