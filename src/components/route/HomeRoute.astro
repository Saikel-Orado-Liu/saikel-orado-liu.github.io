---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HomePage from '@/components/pages/HomePage.astro';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';

export interface Props { locale: string }
const { locale } = Astro.props;
const t = useTranslations(locale as Locale);
---

<BaseLayout title={t('site-title')} description={t('site-description')} locale={locale as Locale}>
  <HomePage locale={locale as Locale} />
</BaseLayout>
