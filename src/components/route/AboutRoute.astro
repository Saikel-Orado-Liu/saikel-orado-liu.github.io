---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AboutPage from '@/components/pages/AboutPage.astro';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';

export interface Props { locale: string }
const { locale } = Astro.props;
const t = useTranslations(locale as Locale);
---

<BaseLayout title={`${t('about-title')} — ${t('site-title')}`} description={t('about-description')} seoDescription={t('about-seo-description')} ogImage="/og-about.png" locale={locale as Locale}>
  <AboutPage locale={locale as Locale} />
</BaseLayout>
