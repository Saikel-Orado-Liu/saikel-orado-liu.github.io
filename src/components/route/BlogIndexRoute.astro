---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogIndex from '@/components/pages/BlogIndex.astro';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';

export interface Props { locale: string }
const { locale } = Astro.props;
const t = useTranslations(locale as Locale);
---

<BaseLayout title={t('blog-title')} description={t('blog-description')} locale={locale as Locale}>
  <BlogIndex locale={locale as Locale} />
</BaseLayout>
