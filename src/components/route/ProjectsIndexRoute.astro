---
import BaseLayout from '@/layouts/BaseLayout.astro';
import ProjectIndex from '@/components/pages/ProjectIndex.astro';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';

export interface Props { locale: string }
const { locale } = Astro.props;
const t = useTranslations(locale as Locale);
---

<BaseLayout title={t('projects-title')} description={t('projects-description')} locale={locale as Locale}>
  <ProjectIndex locale={locale as Locale} />
</BaseLayout>
