---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogTag from '@/components/pages/BlogTag.astro';
import { useTranslations } from '@/i18n';
import type { Locale } from '@/i18n';

export interface Props { locale: string; tag: string }
const { locale, tag } = Astro.props;
const t = useTranslations(locale as Locale);
---

<BaseLayout title={`#${tag} — ${t('blog-title')}`} locale={locale as Locale}>
  <BlogTag locale={locale as Locale} tag={tag} />
</BaseLayout>
