---
import { useTranslations, toDateLocale } from '../../i18n';
import type { Locale } from '../../i18n';

interface Props {
  title: string;
  slug: string;
  date: Date;
  excerpt?: string;
  tags?: string[];
  categories?: string[];
  locale: Locale;
}

const { title, slug, date, excerpt, tags, categories, locale } = Astro.props;
const t = useTranslations(locale);
const prefix = locale === 'zh-cn' ? '' : `/${locale}`;
const href = `${prefix}/blog/${slug}/`;
---

<article class="post-card">
  <div class="post-card-meta">
    {categories && categories.length > 0 && (
      <div class="post-card-categories">
        {categories.slice(0, 2).map(cat => <span class="tag-accent"><span>{cat}</span></span>)}
      </div>
    )}
    <time datetime={date.toISOString()}>
      {date.toLocaleDateString(toDateLocale(locale), { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </div>

  <h2 class="post-card-title">
    <a href={href}>{title}</a>
  </h2>

  {excerpt && <p class="post-card-excerpt">{excerpt}</p>}

  <div class="post-card-footer">
    {tags && tags.length > 0 && (
      <div class="post-card-tags">
        {tags.map(tag => <span class="tag"><span>{tag}</span></span>)}
      </div>
    )}
    <a href={href} class="post-card-link">{t('blog-read-more')} <i class="bx bx-right-arrow-alt"></i></a>
  </div>
</article>

<style>
.post-card {
  position: relative;
  padding: var(--space-2xl) 0;
  border-bottom: 1px solid var(--md-sys-color-outline-variant);
}
.post-card:first-child { padding-top: 0; }

.post-card-meta {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  margin-bottom: var(--space-sm);
  font-size: var(--font-size-sm);
  color: var(--md-sys-color-on-surface-variant);
}

.post-card-categories {
  display: flex;
  gap: var(--space-xs);
}

.post-card-title {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  line-height: 1.3;
  margin: 0 0 var(--space-sm);
}
.post-card-title a {
  color: var(--md-sys-color-on-surface);
  text-decoration: none;
}
.post-card-title a:hover {
  color: var(--clr-secondary-accent);
}

.post-card-excerpt {
  font-size: var(--font-size-base);
  color: var(--md-sys-color-on-surface-variant);
  line-height: var(--line-height-relaxed);
  margin: 0 0 var(--space-md);
  max-width: 65ch;
}

.post-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-md);
  flex-wrap: wrap;
}

.post-card-tags {
  display: flex;
  gap: var(--space-xs);
  flex-wrap: wrap;
}

.post-card-link {
  display: inline-flex;
  align-items: center;
  gap: 2px;
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-medium);
  color: var(--md-sys-color-primary);
  text-decoration: none;
  white-space: nowrap;
  transition: gap 0.2s ease;
}
.post-card-link:hover { gap: 6px; }
.post-card-link i { font-size: 1.1em; }
</style>
