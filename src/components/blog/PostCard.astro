---
import { useTranslations, toDateLocale } from '../../i18n';
import type { Locale } from '../../i18n';

interface Props {
  title: string;
  slug: string;
  date: Date;
  excerpt?: string;
  tags?: string[];
  categories?: string[];
  locale: Locale;
}

const { title, slug, date, excerpt, tags, categories, locale } = Astro.props;
const t = useTranslations(locale);
const prefix = locale === 'zh-cn' ? '' : `/${locale}`;
const href = `${prefix}/blog/${slug}/`;
---

<article class="relative py-12 first:pt-0 border-b border-outline-variant">
  <div class="flex items-center gap-4 mb-2 text-sm text-on-surface-variant">
    {categories && categories.length > 0 && (
      <div class="flex gap-1">
        {categories.slice(0, 2).map(cat => <span class="tag-accent"><span>{cat}</span></span>)}
      </div>
    )}
    <time datetime={date.toISOString()}>
      {date.toLocaleDateString(toDateLocale(locale), { year: 'numeric', month: 'long', day: 'numeric' })}
    </time>
  </div>

  <h2 class="text-2xl font-bold leading-[1.3] mb-2">
    <a href={href} class="text-on-surface no-underline hover:text-secondary">{title}</a>
  </h2>

  {excerpt && <p class="text-base text-on-surface-variant leading-relaxed mb-4 max-w-[65ch]">{excerpt}</p>}

  <div class="flex items-center justify-between gap-4 flex-wrap">
    {tags && tags.length > 0 && (
      <div class="flex gap-1 flex-wrap">
        {tags.map(tag => <span class="tag"><span>{tag}</span></span>)}
      </div>
    )}
    <a href={href} class="inline-flex items-center gap-1 text-sm font-medium text-primary no-underline whitespace-nowrap hover:gap-1.5 transition-[gap] duration-200">{t('blog-read-more')} <i class="bx bx-right-arrow-alt text-[1.1em]"></i></a>
  </div>
</article>
