---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, type Locale } from "../../i18n";
import { buildDocRegistry, getAdjacentDocs, getDocEntry } from "../../utils/docs";
import "../../styles/doc-shared.css";

interface Props {
    slug: string;
    docId: string;
    locale: Locale;
}
const { slug: projectSlug, docId, locale } = Astro.props;
const t = useTranslations(locale);
const prefix = locale === "zh-cn" ? "" : `/${locale}`;

// 1. 文档注册表（侧边栏 + 导航）
const registry = await buildDocRegistry(projectSlug, locale);

// 2. 当前文档 entry
const docEntry = await getDocEntry(docId, locale);
if (!docEntry) return new Response(null, { status: 404 });

const { Content, headings } = await render(docEntry);
const toc = headings.filter((h: any) => h.depth >= 2 && h.depth <= 3);

// H2/H3 分组：每个 H2 自成一组，后继 H3 归入该组
const tocGroups: { h2: any; h3s: any[] }[] = [];
let curGroup: { h2: any; h3s: any[] } | null = null;
for (const h of toc) {
  if (h.depth === 2) {
    curGroup = { h2: h, h3s: [] };
    tocGroups.push(curGroup);
  } else if (h.depth === 3) {
    if (curGroup) {
      curGroup.h3s.push(h);
    } else {
      tocGroups.push({ h2: h, h3s: [] });
    }
  }
}

// 3. 前后篇
const adj = getAdjacentDocs(registry.flatList, docId);

// 4. 当前文档信息
const currentDoc = registry.flatList.find((d) => d.id === docId);
const pageTitle = currentDoc?.title ?? docEntry.data.title;
---

<BaseLayout title={`${pageTitle} — ${projectSlug}`} locale={locale}>
    <div class="doc-layout">
        <!-- 左侧栏：文档树 -->
        <aside class="doc-sidebar doc-sidebar-left">
            <div class="doc-sidebar-inner card">
                <nav class="doc-tree-nav">
                    <a
                        href={`${prefix}/projects/${projectSlug}/`}
                        class="doc-tree-link doc-tree-link--index"
                    >
                        <i class="bx bx-book-open"></i>
                        {t("projects-docs-overview")}
                    </a>

                    {
                        registry.chapters.map((ch) => (
                            <div class="doc-tree-chapter">
                                <p class="doc-tree-chapter-label">
                                    {t(ch.titleKey) !== ch.titleKey
                                        ? t(ch.titleKey)
                                        : ch.slug.replace(/-/g, " ")}
                                </p>
                                {ch.docs.map((doc) => {
                                    const docUrl = `${prefix}/projects/${doc.id}/`;
                                    const isActive = doc.id === docId;
                                    return (
                                        <a
                                            href={docUrl}
                                            class:list={[
                                                "doc-tree-link",
                                                { "doc-tree-link--active": isActive },
                                            ]}
                                        >
                                            {doc.title}
                                        </a>
                                    );
                                })}
                            </div>
                        ))
                    }
                </nav>
            </div>
        </aside>

        <!-- 主内容区 -->
        <main class="doc-main">
            {
                currentDoc && !currentDoc.isIndex && (
                    <nav class="doc-breadcrumb">
                        <a href={`${prefix}/projects/${projectSlug}/`}>
                            <i class="bx bx-book-open" /> {t("projects-docs-overview")}
                        </a>
                        <span class="doc-breadcrumb-sep">/</span>
                        <span>{t(currentDoc.chapterSlug) || currentDoc.chapterSlug}</span>
                    </nav>
                )
            }

            <div class="article-content"><Content /></div>

            <nav class="doc-pager">
                {
                    adj.prev ? (
                        <a
                            href={`${prefix}/projects/${adj.prev.id}/`}
                            rel="prev"
                            class="doc-pager-card"
                        >
                            <svg
                                aria-hidden="true"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                class="doc-pager-arrow"
                            >
                                <>
                                    <defs>
                                        <filter id="pe">
                                            <>
                                                <feDropShadow
                                                    dx="-2"
                                                    dy="-2"
                                                    stdDeviation="0"
                                                    flood-color="rgba(0,0,0,0.33)"
                                                />
                                                <feDropShadow
                                                    dx="1.5"
                                                    dy="1.5"
                                                    stdDeviation="0"
                                                    flood-color="rgba(255,255,255,0.22)"
                                                />
                                            </>
                                        </filter>
                                    </defs>
                                    <g filter="url(#pe)">
                                        <path d="M17 11H9.41l3.3-3.29a1.004 1.004 0 1 0-1.42-1.42l-5 5a1 1 0 0 0-.21.33 1 1 0 0 0 0 .76 1 1 0 0 0 .21.33l5 5a1.002 1.002 0 0 0 1.639-.325 1 1 0 0 0-.219-1.095L9.41 13H17a1 1 0 0 0 0-2Z" />
                                    </g>
                                </>
                            </svg>
                            <span>
                                <span class="doc-pager-label">{t("blog-back")}</span>
                                <span class="doc-pager-title">{adj.prev.title}</span>
                            </span>
                        </a>
                    ) : (
                        <span class="doc-pager-card doc-pager-card--empty"><span class="doc-pager-empty-text">已是最前</span></span>
                    )
                }
                {
                    adj.next ? (
                        <a
                            href={`${prefix}/projects/${adj.next.id}/`}
                            rel="next"
                            class="doc-pager-card next"
                        >
                            <span>
                                <span class="doc-pager-label">{t("blog-read-more")}</span>
                                <span class="doc-pager-title">{adj.next.title}</span>
                            </span>
                            <svg
                                aria-hidden="true"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                class="doc-pager-arrow"
                            >
                                <>
                                    <defs>
                                        <filter id="pe2">
                                            <>
                                                <feDropShadow
                                                    dx="-2"
                                                    dy="-2"
                                                    stdDeviation="0"
                                                    flood-color="rgba(0,0,0,0.33)"
                                                />
                                                <feDropShadow
                                                    dx="1.5"
                                                    dy="1.5"
                                                    stdDeviation="0"
                                                    flood-color="rgba(255,255,255,0.22)"
                                                />
                                            </>
                                        </filter>
                                    </defs>
                                    <g filter="url(#pe2)">
                                        <path d="M17.92 11.62a1.001 1.001 0 0 0-.21-.33l-5-5a1.003 1.003 0 1 0-1.42 1.42l3.3 3.29H7a1 1 0 0 0 0 2h7.59l-3.3 3.29a1.002 1.002 0 0 0 .325 1.639 1 1 0 0 0 1.095-.219l5-5a1 1 0 0 0 .21-.33 1 1 0 0 0 0-.76Z" />
                                    </g>
                                </>
                            </svg>
                        </a>
                    ) : (
                        <span class="doc-pager-card doc-pager-card--empty"><span class="doc-pager-empty-text">已是最后</span></span>
                    )
                }
            </nav>
        </main>

        <!-- 右侧栏：目录树 -->
        {
            tocGroups.length > 0 && (
                <aside class="doc-sidebar doc-sidebar-right">
                    <div class="doc-sidebar-inner card">
                        <p class="doc-toc-label">{t("projects-on-this-page")}</p>
                        <nav class="doc-toc-nav">
                            {tocGroups.map((group) => (
                                <div class="doc-toc-group">
                                    <a href={`#${group.h2.slug}`} class="doc-toc-link doc-toc-depth-2"><span>{group.h2.text}</span></a>
                                    {group.h3s.map((h3: any) => (
                                        <a href={`#${h3.slug}`} class="doc-toc-link doc-toc-depth-3"><span>{h3.text}</span></a>
                                    ))}
                                </div>
                            ))}
                        </nav>
                    </div>
                </aside>
            )
        }
    </div>
</BaseLayout>

<script>
  import { initTocSlider } from '../../scripts/toc-slider';

  function init() {
    initTocSlider();
    // 文章内图片单击 → 全页覆盖放大
    const lightbox = (() => {
      const overlay = document.createElement('div');
      overlay.style.cssText = 'display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.85);cursor:zoom-out;justify-content:center;align-items:center;';
      const img = document.createElement('img');
      img.style.cssText = 'max-width:90vw;max-height:90vh;object-fit:contain;border-radius:8px;box-shadow:0 8px 40px rgba(0,0,0,.5);';
      overlay.appendChild(img);
      overlay.addEventListener('click', () => overlay.style.display = 'none');
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') overlay.style.display = 'none'; });
      document.body.appendChild(overlay);
      return { show(src: string) { img.src = src; overlay.style.display = 'flex'; } };
    })();

    document.querySelectorAll<HTMLImageElement>('.article-content img').forEach(img => {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', () => {
        const src = img.getAttribute('src');
        if (src) lightbox.show(src);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
