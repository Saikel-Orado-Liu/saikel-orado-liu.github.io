---
import { render } from "astro:content";
import { useTranslations, type Locale } from "../../i18n";
import { buildDocRegistry, getAdjacentDocs, getDocEntry, buildTocGroups, getProjectVersions } from "../../utils/docs";
import DocShell from "./DocShell.astro";

interface Props {
    slug: string;
    docId: string;
    locale: Locale;
    version?: string;
}
const { slug: projectSlug, docId, locale, version } = Astro.props;
const t = useTranslations(locale);
const prefix = locale === "zh-cn" ? "" : `/${locale}`;
const versionPrefix = version ? `/${version}` : '';

const registry = await buildDocRegistry(projectSlug, locale, version);
const docEntry = await getDocEntry(docId, locale);
if (!docEntry) return new Response(null, { status: 404 });

const { Content, headings } = await render(docEntry);
const tocGroups = buildTocGroups(headings);
const adj = getAdjacentDocs(registry.flatList, docId);
const currentDoc = registry.flatList.find((d) => d.id === docId);
const pageTitle = currentDoc?.title ?? docEntry.data.title;
const pageDescription = docEntry.data.excerpt;
const docDescription = pageDescription || `${pageTitle} — Texturge Pro 文档页面`;

const pager = {
    prev: adj.prev ? { id: adj.prev.id, title: adj.prev.title } : null,
    next: adj.next ? { id: adj.next.id, title: adj.next.title } : null,
};

const versionInfo = await getProjectVersions(projectSlug);
---

<DocShell
    locale={locale}
    projectSlug={projectSlug}
    pageTitle={pageTitle}
    pageSeoTitle={`${pageTitle} — Texturge Pro | ${t('site-title')}`}
    description={pageDescription}
    seoDescription={docDescription}
    ogImage={`/og-${projectSlug}.png`}
    registry={registry}
    tocGroups={tocGroups}
    activeDocId={docId}
    pager={pager}
    versions={versionInfo?.versions}
    currentVersion={versionInfo?.currentVersion}
    activeVersion={version}
>
    <Fragment slot="before-content">
        {currentDoc && !currentDoc.isIndex && (
            <nav class="doc-breadcrumb">
                <a href={`${prefix}/projects/${projectSlug}${versionPrefix}/`}>
                    <i class="bx bx-book-open" /> {t("projects-docs-overview")}
                </a>
                <span class="doc-breadcrumb-sep">/</span>
                <span>{t(currentDoc.chapterSlug) || currentDoc.chapterSlug}</span>
            </nav>
        )}
    </Fragment>
    <Content />
</DocShell>

<script>
  import { initTocSlider } from '../../scripts/toc-slider';
  import { initLightbox } from '../../scripts/lightbox';

  function init() {
    initTocSlider();
    initLightbox();
  }

  document.addEventListener('astro:page-load', init);
</script>
