---
import { render } from "astro:content";
import { useTranslations, type Locale } from "../../i18n";
import { buildDocRegistry, getAdjacentDocs, getDocEntry, buildTocGroups } from "../../utils/docs";
import DocShell from "./DocShell.astro";

interface Props {
    slug: string;
    docId: string;
    locale: Locale;
}
const { slug: projectSlug, docId, locale } = Astro.props;
const t = useTranslations(locale);
const prefix = locale === "zh-cn" ? "" : `/${locale}`;

const registry = await buildDocRegistry(projectSlug, locale);
const docEntry = await getDocEntry(docId, locale);
if (!docEntry) return new Response(null, { status: 404 });

const { Content, headings } = await render(docEntry);
const tocGroups = buildTocGroups(headings);
const adj = getAdjacentDocs(registry.flatList, docId);
const currentDoc = registry.flatList.find((d) => d.id === docId);
const pageTitle = currentDoc?.title ?? docEntry.data.title;

const pager = {
    prev: adj.prev ? { id: adj.prev.id, title: adj.prev.title } : null,
    next: adj.next ? { id: adj.next.id, title: adj.next.title } : null,
};
---

<DocShell
    locale={locale}
    projectSlug={projectSlug}
    pageTitle={`${pageTitle} — ${projectSlug}`}
    registry={registry}
    tocGroups={tocGroups}
    activeDocId={docId}
    pager={pager}
>
    <Fragment slot="before-content">
        {currentDoc && !currentDoc.isIndex && (
            <nav class="doc-breadcrumb">
                <a href={`${prefix}/projects/${projectSlug}/`}>
                    <i class="bx bx-book-open" /> {t("projects-docs-overview")}
                </a>
                <span class="doc-breadcrumb-sep">/</span>
                <span>{t(currentDoc.chapterSlug) || currentDoc.chapterSlug}</span>
            </nav>
        )}
    </Fragment>
    <Content />
</DocShell>

<script>
  import { initTocSlider } from '../../scripts/toc-slider';
  import { initLightbox } from '../../scripts/lightbox';

  function init() {
    initTocSlider();
    initLightbox();
  }

  document.addEventListener('astro:page-load', init);
</script>
