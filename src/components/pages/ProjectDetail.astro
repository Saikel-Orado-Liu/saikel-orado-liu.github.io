---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, type Locale } from "../../i18n";
import { buildDocRegistry } from "../../utils/docs";
import "../../styles/doc-shared.css";

interface Props {
    locale: Locale;
    slug: string;
}
const { locale, slug } = Astro.props;
const t = useTranslations(locale);
const prefix = locale === "zh-cn" ? "" : `/${locale}`;

// 1. 项目元数据 — 按 locale 优先匹配（glob loader 会吞掉点号）
const projects = await getCollection("projects", ({ data }: any) => !data.draft);
// index.en-us.md → glob 产生 id: "texturge/indexen-us"（无点号）
const project =
    projects.find((p) => {
        if (locale !== "zh-cn") {
            // glob 可能保留或吞掉点号，两种都尝试
            return p.id === `${slug}/index.${locale}` || p.id === `${slug}/index${locale}`;
        }
        return p.id === `${slug}/index` || p.id === slug;
    }) ??
    projects.find((p) => p.id === slug) ??
    projects.find((p) => p.id === `${slug}/index`);
if (!project) return new Response(null, { status: 404 });
const { Content, headings } = await render(project);
const toc = headings.filter((h: any) => h.depth >= 2 && h.depth <= 3);

// H2/H3 分组：每个 H2 自成一组，后继 H3 归入该组
const tocGroups: { h2: any; h3s: any[] }[] = [];
let curGroup: { h2: any; h3s: any[] } | null = null;
for (const h of toc) {
  if (h.depth === 2) {
    curGroup = { h2: h, h3s: [] };
    tocGroups.push(curGroup);
  } else if (h.depth === 3) {
    if (curGroup) {
      curGroup.h3s.push(h);
    } else {
      tocGroups.push({ h2: h, h3s: [] });
    }
  }
}

// 2. 文档注册表
const registry = await buildDocRegistry(slug, locale);
const hasDocs = registry.flatList.length > 0;

// 3. 跨项目前后篇（仅顶层项目，排除子文档）
const topLevelProjects = projects.filter((p) => !p.id.includes("/") || p.id.endsWith("/index"));
const projIdx = topLevelProjects.findIndex((p) => p.id === project.id);
const prevProj = projIdx > 0 ? topLevelProjects[projIdx - 1] : null;
const nextProj = projIdx < topLevelProjects.length - 1 ? topLevelProjects[projIdx + 1] : null;
---

<BaseLayout title={project.data.title} description={project.data.excerpt} locale={locale}>
    <div class="doc-layout">
        <!-- 左侧栏 -->
        <aside class="doc-sidebar doc-sidebar-left">
            <div class="doc-sidebar-inner card">
                {
                    hasDocs ? (
                        <nav class="doc-tree-nav">
                            <a
                                href={`${prefix}/projects/${slug}/`}
                                class="doc-tree-link doc-tree-link--index doc-tree-link--active"
                            >
                                <i class="bx bx-book-open" /> {t("projects-docs-overview")}
                            </a>
                            {registry.chapters.map((ch) => (
                                <div class="doc-tree-chapter">
                                    <p class="doc-tree-chapter-label">
                                        {t(ch.titleKey) !== ch.titleKey
                                            ? t(ch.titleKey)
                                            : ch.slug.replace(/-/g, " ")}
                                    </p>
                                    {ch.docs.map((doc) => (
                                        <a
                                            href={`${prefix}/projects/${doc.id}/`}
                                            class="doc-tree-link"
                                        >
                                            {doc.title}
                                        </a>
                                    ))}
                                </div>
                            ))}
                        </nav>
                    ) : (
                        <nav class="doc-sidebar-nav">
                            {projects.map((p) => (
                                <a
                                    href={`${prefix}/projects/${p.id}/`}
                                    class:list={[
                                        "doc-sidebar-link",
                                        { "doc-sidebar-link--active": p.id === slug },
                                    ]}
                                >
                                    {p.data.title}
                                </a>
                            ))}
                        </nav>
                    )
                }
            </div>
        </aside>

        <!-- 主内容区 — 与 /spec/ 完全相同的 doc 模板 -->
        <main class="doc-main">
            <div class="doc-meta">
                {
                    project.data.tags && project.data.tags.length > 0 && (
                        <div class="doc-tags">
                            {project.data.tags.map((tag: string) => (
                                <span class="tag">
                                    <span>{tag}</span>
                                </span>
                            ))}
                        </div>
                    )
                }
                <div class="doc-links">
                    {
                        project.data.github && (
                            <a
                                href={project.data.github}
                                class="btn btn-outline"
                                target="_blank"
                                rel="noopener"
                            >
                                <i class="bx bxl-github" /> <span>GitHub</span>
                            </a>
                        )
                    }
                    {
                        project.data.demo && (
                            <a
                                href={project.data.demo}
                                class="btn btn-outline"
                                target="_blank"
                                rel="noopener"
                            >
                                <i class="bx bx-link-external" /> <span>{t("projects-demo")}</span>
                            </a>
                        )
                    }
                </div>
            </div>

            <div class="article-content"><Content /></div>

            {(prevProj || nextProj) && <nav class="doc-pager">
                {prevProj && (
                        <a
                            href={`${prefix}/projects/${prevProj.id}/`}
                            rel="prev"
                            class="doc-pager-card"
                        >
                            <svg
                                aria-hidden="true"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                class="doc-pager-arrow"
                            >
                                <>
                                    <defs>
                                        <filter id="pe">
                                            <>
                                                <feDropShadow
                                                    dx="-2"
                                                    dy="-2"
                                                    stdDeviation="0"
                                                    flood-color="rgba(0,0,0,0.33)"
                                                />
                                                <feDropShadow
                                                    dx="1.5"
                                                    dy="1.5"
                                                    stdDeviation="0"
                                                    flood-color="rgba(255,255,255,0.22)"
                                                />
                                            </>
                                        </filter>
                                    </defs>
                                    <g filter="url(#pe)">
                                        <path d="M17 11H9.41l3.3-3.29a1.004 1.004 0 1 0-1.42-1.42l-5 5a1 1 0 0 0-.21.33 1 1 0 0 0 0 .76 1 1 0 0 0 .21.33l5 5a1.002 1.002 0 0 0 1.639-.325 1 1 0 0 0-.219-1.095L9.41 13H17a1 1 0 0 0 0-2Z" />
                                    </g>
                                </>
                            </svg>
                            <span>
                                <span class="doc-pager-label">{t("blog-back")}</span>
                                <span class="doc-pager-title">{prevProj.data.title}</span>
                            </span>
                        </a>
                )}
                {nextProj && (
                        <a
                            href={`${prefix}/projects/${nextProj.id}/`}
                            rel="next"
                            class="doc-pager-card next"
                        >
                            <span>
                                <span class="doc-pager-label">{t("blog-read-more")}</span>
                                <span class="doc-pager-title">{nextProj.data.title}</span>
                            </span>
                            <svg
                                aria-hidden="true"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                                class="doc-pager-arrow"
                            >
                                <>
                                    <defs>
                                        <filter id="pe2">
                                            <>
                                                <feDropShadow
                                                    dx="-2"
                                                    dy="-2"
                                                    stdDeviation="0"
                                                    flood-color="rgba(0,0,0,0.33)"
                                                />
                                                <feDropShadow
                                                    dx="1.5"
                                                    dy="1.5"
                                                    stdDeviation="0"
                                                    flood-color="rgba(255,255,255,0.22)"
                                                />
                                            </>
                                        </filter>
                                    </defs>
                                    <g filter="url(#pe2)">
                                        <path d="M17.92 11.62a1.001 1.001 0 0 0-.21-.33l-5-5a1.003 1.003 0 1 0-1.42 1.42l3.3 3.29H7a1 1 0 0 0 0 2h7.59l-3.3 3.29a1.002 1.002 0 0 0 .325 1.639 1 1 0 0 0 1.095-.219l5-5a1 1 0 0 0 .21-.33 1 1 0 0 0 0-.76Z" />
                                    </g>
                                </>
                            </svg>
                        </a>
                )}
            </nav>}
        </main>

        {
            tocGroups.length > 0 && (
                <aside class="doc-sidebar doc-sidebar-right">
                    <div class="doc-sidebar-inner card">
                        <p class="doc-toc-label">{t("projects-on-this-page")}</p>
                        <nav class="doc-toc-nav">
                            {tocGroups.map((group) => (
                                <div class="doc-toc-group">
                                    <a href={`#${group.h2.slug}`} class="doc-toc-link doc-toc-depth-2"><span>{group.h2.text}</span></a>
                                    {group.h3s.map((h3: any) => (
                                        <a href={`#${h3.slug}`} class="doc-toc-link doc-toc-depth-3"><span>{h3.text}</span></a>
                                    ))}
                                </div>
                            ))}
                        </nav>
                    </div>
                </aside>
            )
        }
    </div>
</BaseLayout>

<script>
  import { initTocSlider } from '../../scripts/toc-slider';

  function init() {
    initTocSlider();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
