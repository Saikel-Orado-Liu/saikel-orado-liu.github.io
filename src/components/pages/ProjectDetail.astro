---
import { getCollection, render } from "astro:content";
import { useTranslations, type Locale } from "../../i18n";
import { buildDocRegistry, buildTocGroups } from "../../utils/docs";
import DocShell from "./DocShell.astro";

interface Props {
    locale: Locale;
    slug: string;
}
const { locale, slug } = Astro.props;
const t = useTranslations(locale);

// 1. 项目元数据 — 按 locale 优先匹配
const projects = await getCollection("projects", ({ data }: any) => !data.draft);
const project =
    projects.find((p) => {
        if (locale !== "zh-cn") {
            return p.id === `${slug}/${slug}.${locale}` || p.id === `${slug}/${slug}${locale}`
                || p.id === `${slug}/index.${locale}` || p.id === `${slug}/index${locale}`;
        }
        return p.id === `${slug}/${slug}` || p.id === `${slug}/index` || p.id === slug;
    }) ??
    projects.find((p) => p.id === slug) ??
    projects.find((p) => p.id === `${slug}/${slug}` || p.id === `${slug}/index`);
if (!project) return new Response(null, { status: 404 });
const { Content, headings } = await render(project);
const tocGroups = buildTocGroups(headings);

// 2. 文档注册表
const registry = await buildDocRegistry(slug, locale);
---

<DocShell
    locale={locale}
    projectSlug={slug}
    pageTitle={project.data.title}
    description={project.data.excerpt}
    registry={registry}
    tocGroups={tocGroups}
    activeSidebarLink={slug}
>
    <Fragment slot="before-content">
        <div class="doc-meta">
            {project.data.tags && project.data.tags.length > 0 && (
                <div class="doc-tags">
                    {project.data.tags.map((tag: string) => (
                        <span class="tag"><span>{tag}</span></span>
                    ))}
                </div>
            )}
            <div class="doc-links">
                {project.data.github && (
                    <a href={project.data.github} class="btn btn-outline" target="_blank" rel="noopener">
                        <i class="bx bxl-github" /> <span>GitHub</span>
                    </a>
                )}
                {project.data.demo && (
                    <a href={project.data.demo} class="btn btn-outline" target="_blank" rel="noopener">
                        <i class="bx bx-link-external" /> <span>{t("projects-demo")}</span>
                    </a>
                )}
            </div>
        </div>
    </Fragment>
    <Content />
</DocShell>

<script>
  import { initTocSlider } from '../../scripts/toc-slider';

  function init() {
    initTocSlider();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
