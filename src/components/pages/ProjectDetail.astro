---
import { getCollection, render } from "astro:content";
import { useTranslations, type Locale } from "../../i18n";
import { buildDocRegistry, buildTocGroups, getProjectVersions } from "../../utils/docs";
import DocShell from "./DocShell.astro";

interface Props {
    locale: Locale;
    slug: string;
    version?: string;
}
const { locale, slug, version } = Astro.props;
const t = useTranslations(locale);

// 1. Project metadata — match by locale + version
const projects = await getCollection("projects", ({ data }: any) => !data.draft);

const project =
    projects.find((p) => {
        if (version) {
            // 旧版：匹配 slug/v1.0/slug 或 slug/v1.0/index
            if (locale !== "zh-cn") {
                return p.id === `${slug}/${version}/${slug}.${locale}` || p.id === `${slug}/${version}/${slug}${locale}`
                    || p.id === `${slug}/${version}/index.${locale}` || p.id === `${slug}/${version}/index${locale}`;
            }
            return p.id === `${slug}/${version}/${slug}` || p.id === `${slug}/${version}/index`;
        }
        // 最新版
        if (locale !== "zh-cn") {
            return p.id === `${slug}/${slug}.${locale}` || p.id === `${slug}/${slug}${locale}`
                || p.id === `${slug}/index.${locale}` || p.id === `${slug}/index${locale}`;
        }
        return p.id === `${slug}/${slug}` || p.id === `${slug}/index` || p.id === slug;
    }) ??
    projects.find((p) => p.id === slug) ??
    projects.find((p) => p.id === `${slug}/${slug}` || p.id === `${slug}/index`);
if (!project) return new Response(null, { status: 404 });
const { Content, headings } = await render(project);
const tocGroups = buildTocGroups(headings);

// 2. 文档注册表
const registry = await buildDocRegistry(slug, locale, version);

// 3. 版本信息
const versionInfo = await getProjectVersions(slug);
---

<DocShell
    locale={locale}
    projectSlug={slug}
    pageTitle={project.data.title}
    description={project.data.excerpt}
    registry={registry}
    tocGroups={tocGroups}
    activeSidebarLink={slug}
    versions={versionInfo?.versions}
    currentVersion={versionInfo?.currentVersion}
    activeVersion={version}
>
    <Fragment slot="before-content">
        <div class="doc-meta">
            {project.data.tags && project.data.tags.length > 0 && (
                <div class="doc-tags">
                    {project.data.tags.map((tag: string) => (
                        <span class="tag"><span>{tag}</span></span>
                    ))}
                </div>
            )}
            <div class="doc-links">
                {project.data.github && (
                    <a href={project.data.github} class="btn btn-outline" target="_blank" rel="noopener">
                        <i class="bx bxl-github" /> <span>GitHub</span>
                    </a>
                )}
                {project.data.demo && (
                    <a href={project.data.demo} class="btn btn-outline" target="_blank" rel="noopener">
                        <i class="bx bx-link-external" /> <span>{t("projects-demo")}</span>
                    </a>
                )}
            </div>
        </div>
    </Fragment>
    <Content />
</DocShell>

<script>
  import { initTocSlider } from '../../scripts/toc-slider';

  function init() {
    initTocSlider();
  }

  document.addEventListener('astro:page-load', init);
</script>
