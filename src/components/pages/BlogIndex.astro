---
import { getLocalizedPosts, getAllTags } from '../../utils/content';
import PostCard from '../blog/PostCard.astro';
import { useTranslations } from '../../i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../i18n';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const posts = await getLocalizedPosts(locale);
const tags = await getAllTags(locale);
---

<div class="blog-page">
  <header class="blog-header">
    <h1 class="blog-title">{t('blog-title')}</h1>
    <p class="blog-desc">{t('blog-description')}</p>

    {
      tags.length > 0 && (
        <nav class="blog-tags" aria-label={t('blog-tags')}>
          {tags.map(([tag, _count]) => (
            <a href={getRelativeLocaleUrl(locale, `/blog/tag/${tag}/`)} class="tag"><span>{tag}</span></a>
          ))}
        </nav>
      )
    }
  </header>

  {posts.length > 0 ? (
    <div class="blog-list">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          slug={post.id}
          date={post.data.date}
          excerpt={post.data.excerpt}
          tags={post.data.tags}
          categories={post.data.categories}
          locale={locale}
        />
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <i class="bx bx-news"></i>
      <p>{t('blog-empty')}</p>
    </div>
  )}
</div>

<style>
.blog-page {
  max-width: 720px;
  margin: 0 auto;
  padding: var(--space-4xl) var(--space-lg) var(--space-4xl);
}

/* Header */
.blog-header {
  margin-bottom: var(--space-3xl);
}

.blog-title {
  font-size: var(--font-size-4xl);
  font-weight: var(--font-weight-bold);
  color: var(--md-sys-color-on-surface);
  margin: 0 0 var(--space-sm);
}

.blog-desc {
  font-size: var(--font-size-lg);
  color: var(--md-sys-color-on-surface-variant);
  margin: 0 0 var(--space-xl);
  max-width: 60ch;
}

/* Tags bar — horizontal wrapped, clean */
.blog-tags {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

/* Post list */
.blog-list {
  display: flex;
  flex-direction: column;
}
</style>
