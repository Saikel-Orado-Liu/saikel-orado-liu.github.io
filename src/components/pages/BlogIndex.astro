---
import { getLocalizedPosts, getAllTags } from '../../utils/content';
import PostCard from '../blog/PostCard.astro';
import { useTranslations } from '../../i18n';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../i18n';

interface Props { locale: Locale; }
const { locale } = Astro.props;
const t = useTranslations(locale);
const posts = await getLocalizedPosts(locale);
const tags = await getAllTags(locale);
---

<div class="container-narrow pt-16 pb-16">
  <header class="mb-12">
    <h1 class="section-title text-4xl mb-2">{t('blog-title')}</h1>
    <p class="section-subtitle text-lg text-on-surface-variant mb-6 max-w-[60ch]">{t('blog-description')}</p>

    {
      tags.length > 0 && (
        <nav class="flex flex-wrap gap-1" aria-label={t('blog-tags')}>
          {tags.map(([tag, _count]) => (
            <a href={getRelativeLocaleUrl(locale, `/blog/tag/${tag}/`)} class="tag"><span>{tag}</span></a>
          ))}
        </nav>
      )
    }
  </header>

  {posts.length > 0 ? (
    <div class="flex flex-col">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          slug={post.id}
          date={post.data.date}
          excerpt={post.data.excerpt}
          tags={post.data.tags}
          categories={post.data.categories}
          locale={locale}
        />
      ))}
    </div>
  ) : (
    <div class="empty-state">
      <i class="bx bx-news"></i>
      <p>{t('blog-empty')}</p>
    </div>
  )}
</div>
