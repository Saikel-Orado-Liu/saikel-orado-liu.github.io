---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations, type Locale } from "../../i18n";
import type { DocRegistry } from "../../utils/docs";
import "../../styles/doc-shared.css";
import VersionWheel from "../doc/VersionWheel.astro";
import TocCard from "../doc/TocCard.astro";
import DocTree from "../doc/DocTree.astro";
import DocPager from "../doc/DocPager.astro";

interface Props {
  locale: Locale;
  projectSlug: string;
  pageTitle: string;
  description?: string;
  registry: DocRegistry;
  tocGroups: { h2: any; h3s: any[] }[];
  activeDocId?: string;
  activeSidebarLink?: string;
  pager?: { prev: { id: string; title: string } | null; next: { id: string; title: string } | null };
  emptyPrevText?: string;
  emptyNextText?: string;
  versions?: string[];
  currentVersion?: string;
  activeVersion?: string;
}

const {
  locale,
  projectSlug,
  pageTitle,
  description,
  registry,
  tocGroups,
  activeDocId,
  activeSidebarLink,
  pager,
  emptyPrevText = "已是最前",
  emptyNextText = "已是最后",
  versions,
  currentVersion,
  activeVersion,
} = Astro.props;
const t = useTranslations(locale);
const prefix = locale === "zh-cn" ? "" : `/${locale}`;
const showWheel = versions && versions.length > 1;
---

<BaseLayout title={pageTitle} description={description} locale={locale}>
    <div class="doc-layout">
        <aside class="doc-sidebar doc-sidebar-left">
            <DocTree locale={locale} projectSlug={projectSlug} activeVersion={activeVersion} registry={registry} activeDocId={activeDocId} activeSidebarLink={activeSidebarLink} />
        </aside>

        <main class="doc-main">
            <slot name="before-content" />
            <div class="article-content"><slot /></div>
            {pager && <DocPager locale={locale} prefix={prefix} pager={pager} emptyPrevText={emptyPrevText} emptyNextText={emptyNextText} />}
        </main>

        {(showWheel || tocGroups.length > 0) && (
            <aside class="doc-sidebar doc-sidebar-right">
                {showWheel && <VersionWheel locale={locale} versions={versions!} currentVersion={currentVersion!} activeVersion={activeVersion} projectSlug={projectSlug} prefix={prefix} />}
                <TocCard locale={locale} tocGroups={tocGroups} />
            </aside>
        )}
    </div>
</BaseLayout>
