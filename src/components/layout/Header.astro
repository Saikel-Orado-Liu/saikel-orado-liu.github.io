---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { localeLabels, useTranslations, supportedLocales, stripLocalePrefix } from '../../i18n';
import type { Locale } from '../../i18n';

const currentLocale = (Astro.currentLocale || 'zh-cn') as Locale;
const t = useTranslations(currentLocale);

const navItems: { key: string; path: string }[] = [
  { key: 'nav-home', path: '/' },
  { key: 'nav-articles', path: '/blog/' },
  { key: 'nav-tools', path: '/projects/' },
  { key: 'nav-games', path: '/game/' },
  { key: 'nav-about', path: '/about/' },
];
---

<header class="navbar plate">
  <div class="navbar-inner">
    <div class="navbar-main">
      <a href={getRelativeLocaleUrl(currentLocale, '/')} class="navbar-brand" aria-label="Home">
        <img class="navbar-logo" src="https://avatars.githubusercontent.com/u/88531138" alt="Logo" width="32" height="32" />
        <span class="navbar-title">{currentLocale === 'zh-cn' ? '游戏极客-Saikel' : 'GameGeek-Saikel'}</span>
      </a>
    </div>

    <nav class="navbar-nav" aria-label="Main navigation">
      <ul>
        {navItems.map(item => (
          <li>
            <a href={getRelativeLocaleUrl(currentLocale, item.path)}
               class:list={{ active: item.path === '/'
                  ? Astro.url.pathname === getRelativeLocaleUrl(currentLocale, '/')
                  : Astro.url.pathname.startsWith(getRelativeLocaleUrl(currentLocale, item.path)) }}>
              <span>{t(item.key)}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="navbar-widget">
      <button class="widget-item theme-toggle" aria-label="Toggle theme">
        <i class="bx bx-moon"></i>
      </button>

      <div class="widget-item lang-switcher">
        <span class="lang-trigger">
          <svg class="lang-icon" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" stroke="currentColor" stroke-width="0.6" stroke-linejoin="round" aria-hidden="true">
            <path fill-rule="evenodd" d="M8.516 3a.94.94 0 0 0-.941.94v1.15H2.94a.94.94 0 1 0 0 1.882h7.362a7.422 7.422 0 0 1-1.787 3.958 7.42 7.42 0 0 1-1.422-2.425.94.94 0 1 0-1.774.627 9.303 9.303 0 0 0 1.785 3.043 7.422 7.422 0 0 1-4.164 1.278.94.94 0 1 0 0 1.881 9.303 9.303 0 0 0 5.575-1.855 9.303 9.303 0 0 0 4.11 1.74l-.763 1.525a.968.968 0 0 0-.016.034l-1.385 2.77a.94.94 0 1 0 1.683.841l1.133-2.267h5.806l1.134 2.267a.94.94 0 0 0 1.683-.841l-1.385-2.769a.95.95 0 0 0-.018-.036l-3.476-6.951a.94.94 0 0 0-1.682 0l-1.82 3.639a7.423 7.423 0 0 1-3.593-1.256 9.303 9.303 0 0 0 2.27-5.203h1.894a.94.94 0 0 0 0-1.881H9.456V3.94A.94.94 0 0 0 8.516 3Zm6.426 11.794a1.068 1.068 0 0 1-.02.039l-.703 1.407h3.924l-1.962-3.924-1.24 2.478Z" clip-rule="evenodd"/>
        </span>
        <div class="lang-dropdown">
      <ul class="groove">
            {supportedLocales.map(loc => (
              <li>
                <a href={getRelativeLocaleUrl(loc, stripLocalePrefix(Astro.url.pathname) || '/')}
                   data-lang={loc}
                   class:list={{ active: currentLocale === loc }}>
                  <span>{localeLabels[loc]}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { initLangSlider, repositionLangSlider } from '../../scripts/nav-slider';

  initLangSlider();

  // 语言切换时保存偏好到 localStorage
  document.querySelector('.lang-dropdown')?.addEventListener('click', (e) => {
    const link = (e.target as Element).closest('a[data-lang]') as HTMLAnchorElement | null;
    if (link) {
      try { localStorage.setItem('user-locale', link.dataset.lang!); } catch (_) {}
    }
  });

  function closeLang() {
    document.querySelector('.lang-switcher.lang-open')?.classList.remove('lang-open');
  }

  document.addEventListener('click', (e) => {
    const target = e.target as Element | null;
    const trigger = target?.closest('.lang-trigger');
    const switcher = trigger?.closest('.lang-switcher');

    document.querySelectorAll('.lang-switcher.lang-open').forEach(el => {
      if (el !== switcher) el.classList.remove('lang-open');
    });

    if (switcher) {
      switcher.classList.toggle('lang-open');
      if (switcher.classList.contains('lang-open')) {
        // dropdown 可见后重定位滑块
        requestAnimationFrame(() => repositionLangSlider());
      }
    } else if (!target?.closest('.lang-dropdown')) {
      closeLang();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLang();
  });
</script>
