---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations } from '../../i18n';
import type { Locale } from '../../i18n';
import LangSwitcher from './LangSwitcher.astro';

const locale = (Astro.currentLocale || 'zh-cn') as Locale;
const t = useTranslations(locale);

const navItems: { key: string; path: string }[] = [
  { key: 'nav-home', path: '/' },
  { key: 'nav-articles', path: '/blog/' },
  { key: 'nav-tools', path: '/projects/' },
  { key: 'nav-games', path: '/game/' },
  { key: 'nav-about', path: '/about/' },
];
---

<header class="navbar plate">
  <div class="navbar-inner">
    <div class="navbar-main">
      <a href={getRelativeLocaleUrl(locale, '/')} class="navbar-brand" aria-label="Home">
        <img class="navbar-logo" src="https://avatars.githubusercontent.com/u/88531138" alt="Logo" width="32" height="32" />
        <span class="navbar-title">{locale === 'zh-cn' ? '游戏极客-Saikel' : 'GameGeek-Saikel'}</span>
      </a>
    </div>

    <nav class="navbar-nav" aria-label="Main navigation">
      <ul>
        {navItems.map(item => (
          <li>
            <a href={getRelativeLocaleUrl(locale, item.path)}
               class:list={{ active: item.path === '/'
                  ? Astro.url.pathname === getRelativeLocaleUrl(locale, '/')
                  : Astro.url.pathname.startsWith(getRelativeLocaleUrl(locale, item.path)) }}>
              <span>{t(item.key)}</span>
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="navbar-widget">
      <button class="widget-item theme-toggle" aria-label="Toggle theme">
        <svg class="theme-icon" viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
          <path class="theme-icon-moon" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          <path class="theme-icon-sun" d="M12 7a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0-5a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0V3a1 1 0 0 1 1-1zm0 18a1 1 0 0 1 1 1v1a1 1 0 1 1-2 0v-1a1 1 0 0 1 1-1zm9-9a1 1 0 0 1 0 2h-1a1 1 0 1 1 0-2h1zM3 12a1 1 0 0 1 0 2H2a1 1 0 1 1 0-2h1zm15.36-6.36a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0zM6.34 17.66a1 1 0 0 1 0 1.41l-.71.71a1 1 0 1 1-1.41-1.41l.71-.71a1 1 0 0 1 1.41 0zM17.66 17.66a1 1 0 0 1 1.41 0l.71.71a1 1 0 1 1-1.41 1.41l-.71-.71a1 1 0 0 1 0-1.41zM6.34 6.34a1 1 0 0 1-1.41 0l-.71-.71a1 1 0 0 1 1.41-1.41l.71.71a1 1 0 0 1 0 1.41z"/>
        </svg>
        <style>
          .theme-icon-sun { display: none; }
          :root.light-style .theme-icon-sun { display: block; }
          :root.light-style .theme-icon-moon { display: none; }
        </style>
      </button>

      <LangSwitcher locale={locale} />
    </div>
  </div>
</header>
