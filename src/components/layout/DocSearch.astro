---
import { useTranslations } from '../../i18n';
import type { Locale } from '../../i18n';

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const placeholder = t('doc-search-placeholder');
const navLabel = t('doc-search-navigate');
const selLabel = t('doc-search-select');
const closeLabel = t('doc-search-close');
const searchingLabel = t('doc-search-searching');
const emptyLabel = t('doc-search-empty');
---

<div class="search-container" data-search-container data-search-searching={searchingLabel} data-search-empty={emptyLabel}>
    <div class="search-input-wrapper">
        <svg class="search-icon" viewBox="0 0 18 18" width="16" height="16" fill="none" aria-hidden="true">
            <path d="M12.755 11.255h-.79l-.28-.27A6.471 6.471 0 0 0 13.255 6.76a6.5 6.5 0 1 0-6.5 6.5 6.471 6.471 0 0 0 4.23-1.53l.27.28v.79l5 4.99 1.49-1.49-4.99-5Zm-6 0a4.5 4.5 0 1 1 0-9 4.5 4.5 0 0 1 0 9Z" fill="currentColor"/>
        </svg>
        <input type="search" class="search-input" placeholder={placeholder} aria-label={placeholder} autocomplete="off" autocapitalize="none" enterkeyhint="search" />
        <span class="pf-trigger-shortcut" aria-hidden="true">Ctrl + K</span>
    </div>
    <div class="search-dropdown card" hidden>
        <div class="search-results-groove" aria-hidden="true"></div>
        <div class="search-results" role="listbox" aria-label="Search results"></div>
        <div class="search-footer" aria-hidden="true">
            <span class="search-footer-hint"><kbd>↑</kbd><kbd>↓</kbd> <span class="search-footer-label">{navLabel}</span></span>
            <span class="search-footer-hint"><kbd>↵</kbd> <span class="search-footer-label">{selLabel}</span></span>
            <span class="search-footer-hint"><kbd>esc</kbd> <span class="search-footer-label">{closeLabel}</span></span>
        </div>
    </div>
</div>

<script is:inline>
(function() {
    'use strict';

    var LOG = function() { var args=['[DocSearch]']; for (var i=0; i<arguments.length; i++) args.push(arguments[i]); console.log.apply(console, args); };

    var DS = window.__docSearchShared || {};

    function ensurePagefindForLocale(locale) {
        if (DS.pagefind && DS.pagefindLocale === locale) {
            return DS.pagefindPromise;
        }
        LOG('ensurePagefindForLocale: switching from', DS.pagefindLocale, 'to', locale);
        // destroy() 是 async 的，必须等它完成再 import，否则新模块拿到已终止的 worker
        var oldPf = DS.pagefind;
        DS.pagefind = null;
        DS.pagefindLocale = locale;
        DS.pagefindPromise = (oldPf ? oldPf.destroy().catch(function(){}) : Promise.resolve())
            .then(function() { return import('/pagefind/pagefind.js'); })
            .then(function(pf) {
                DS.pagefind = pf;
                LOG('ensurePagefindForLocale: Pagefind ready for', locale);
                return pf;
            }).catch(function(err) {
                console.error('[DocSearch] load error:', err);
                DS.pagefindPromise = null;
            });
        return DS.pagefindPromise;
    }

    if (!DS.ctrlKBound) {
        DS.ctrlKBound = true;
        document.addEventListener('keydown', function(e) {
            if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                e.preventDefault();
                var inp = document.querySelector('[data-search-container] .search-input');
                if (inp) { inp.focus(); inp.select(); }
            }
        });
    }

    window.__docSearchShared = DS;

    var currentSearch = 0;
    var activeIndex = -1;
    var resultElements = [];

    function getCurrentLocale() {
        var p = window.location.pathname;
        var PF = ['en-us','ja-jp','ko-kr','ar-sa','es-es','fr-fr','pt-pt','ru-ru','de-de'];
        for (var i = 0; i < PF.length; i++) {
            var l = PF[i];
            if (p.indexOf('/' + l + '/') === 0 || p === '/' + l) return l;
        }
        return 'zh-cn';
    }

    function localizeUrl(url) {
        var locale = getCurrentLocale();
        if (locale === 'zh-cn') return url;
        var PF = ['en-us','ja-jp','ko-kr','ar-sa','es-es','fr-fr','pt-pt','ru-ru','de-de'];
        var u = url;
        try { u = new URL(url).pathname; } catch(e) {}
        if (u.charAt(0) !== '/') u = '/' + u;
        for (var j = 0; j < PF.length; j++) {
            if (u.indexOf('/' + PF[j] + '/') === 0) return url;
        }
        return '/' + locale + u;
    }

    function init() {
        var container = document.querySelector('[data-search-container]');
        if (!container) return;
        if (container.dataset.searchInit === 'true') return;
        container.dataset.searchInit = 'true';
        LOG('init: locale=' + getCurrentLocale() + ' hasPagefind=' + !!DS.pagefind + ' pagefindLocale=' + (DS.pagefindLocale||'none'));

        var input = container.querySelector('.search-input');
        var dropdown = container.querySelector('.search-dropdown');
        var resultsContainer = container.querySelector('.search-results');
        if (!input || !dropdown || !resultsContainer) return;

        function updateScrollMask() {
            var atTop = resultsContainer.scrollTop <= 0;
            var atBottom = resultsContainer.scrollTop + resultsContainer.clientHeight >= resultsContainer.scrollHeight - 1;
            resultsContainer.classList.toggle('at-top', atTop);
            resultsContainer.classList.toggle('at-bottom', atBottom);
        }
        resultsContainer.addEventListener('scroll', updateScrollMask, { passive: true });

        function scrollToReveal(el) {
            var maskSize = 24;
            var elTop = el.offsetTop, elBottom = elTop + el.offsetHeight;
            var viewTop = resultsContainer.scrollTop, viewBottom = viewTop + resultsContainer.clientHeight;
            if (elTop < viewTop + maskSize) {
                resultsContainer.scrollTo({ top: Math.max(0, elTop - maskSize), behavior: 'smooth' });
            } else if (elBottom > viewBottom - maskSize) {
                resultsContainer.scrollTo({ top: elBottom + maskSize - resultsContainer.clientHeight, behavior: 'smooth' });
            }
        }
        resultsContainer.addEventListener('mouseover', function(e) {
            var item = e.target.closest('.search-result-item');
            if (item) scrollToReveal(item);
        });

        input.oninput = null;
        input.addEventListener('input', handleInput);
        input.onkeydown = null;
        input.addEventListener('keydown', handleKeydown);

        function handleInput() {
            var term = input.value.trim();
            var searchId = ++currentSearch;
            if (!term) { closeDropdown(); return; }
            showLoading();

            var locale = getCurrentLocale();
            LOG('handleInput: term="'+term+'" locale='+locale+' pagefindLocale='+(DS.pagefindLocale||'none'));
            ensurePagefindForLocale(locale).then(function() {
                if (searchId !== currentSearch) return;
                var pf = DS.pagefind;
                if (!pf) return;

                pf.debouncedSearch(term, {}, 300).then(function(result) {
                    if (searchId !== currentSearch) return;
                    if (!result) return;
                    LOG('handleInput: got '+result.results.length+' results');
                    if (result.results.length === 0) { showEmpty(); return; }
                    renderResults(result.results.slice(0, 8));
                }).catch(function(err) {
                    console.error('[DocSearch] search error:', err);
                });
            });
        }

        function handleKeydown(e) {
            if (e.key === 'Escape') { closeDropdown(); input.blur(); return; }
            if (e.key === 'ArrowDown') {
                e.preventDefault();
                if (!dropdown.hidden && resultElements.length > 0) {
                    activeIndex = Math.min(activeIndex + 1, resultElements.length - 1);
                    updateActive();
                }
                return;
            }
            if (e.key === 'ArrowUp') {
                e.preventDefault();
                if (!dropdown.hidden && resultElements.length > 0) {
                    activeIndex = Math.max(activeIndex - 1, 0);
                    updateActive();
                }
                return;
            }
            if (e.key === 'Enter') {
                if (!dropdown.hidden && activeIndex >= 0 && resultElements[activeIndex]) {
                    resultElements[activeIndex].click();
                    closeDropdown();
                }
                return;
            }
        }

        function openDropdown() { dropdown.hidden = false; dropdown.classList.add('open'); }
        function closeDropdown() {
            dropdown.hidden = true; dropdown.classList.remove('open');
            resultsContainer.innerHTML = ''; resultsContainer.classList.remove('at-top', 'at-bottom');
            activeIndex = -1; resultElements = [];
        }
        function showLoading() { dropdown.hidden = false; resultsContainer.innerHTML = '<div class="search-status search-loading">'+container.dataset.searchSearching+'</div>'; }
        function showEmpty() { dropdown.hidden = false; resultsContainer.innerHTML = '<div class="search-status search-empty">'+container.dataset.searchEmpty+'</div>'; }

        function renderResults(results) {
            return Promise.all(results.map(function(r, idx) {
                return r.data().then(function(data) {
                    var a = document.createElement('a');
                    a.className = 'search-result-item';
                    a.href = localizeUrl(data.url);
                    a.setAttribute('role', 'option');
                    var title = document.createElement('div');
                    title.className = 'search-result-title';
                    title.textContent = (data.meta && data.meta.title) || 'Untitled';
                    a.appendChild(title);
                    var desc = data.excerpt || data.plain_excerpt || (data.meta && data.meta.description)
                        || (data.content ? data.content.substring(0, 120).replace(/\s+/g, ' ').trim() + '\u2026' : '');
                    if (desc) {
                        var excerpt = document.createElement('div');
                        excerpt.className = 'search-result-excerpt';
                        excerpt.innerHTML = desc;
                        a.appendChild(excerpt);
                    }
                    if (idx === 0) LOG('renderResults: first title="'+title.textContent+'" url='+a.href);
                    return a;
                });
            })).then(function(items) {
                LOG('renderResults: showing '+items.length+' items');
                resultsContainer.innerHTML = '';
                items.forEach(function(el) { resultsContainer.appendChild(el); });
                resultElements = items;
                activeIndex = -1;
                openDropdown();
                requestAnimationFrame(updateScrollMask);
            });
        }

        function updateActive() {
            resultElements.forEach(function(el, i) {
                el.classList.toggle('active', i === activeIndex);
                el.setAttribute('aria-selected', String(i === activeIndex));
            });
            if (activeIndex >= 0 && resultElements[activeIndex]) {
                scrollToReveal(resultElements[activeIndex]);
            }
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

    document.addEventListener('astro:after-swap', function() {
        LOG('astro:after-swap locale='+getCurrentLocale()+' pagefindLocale='+(DS.pagefindLocale||'none'));
        var container = document.querySelector('[data-search-container]');
        if (container) { delete container.dataset.searchInit; }
        requestAnimationFrame(function() { init(); });
    });
})();
</script>
