---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { supportedLocales, toOgLocale, toHreflangLocale, stripLocalePrefix, getLocaleDir, locales } from '../i18n';
import type { Locale } from '../i18n';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/tokens.css';
import '../styles/global.css';
import '../styles/base.css';
import '../styles/material.css';
import '../styles/components.css';
import '../styles/header.css';
import '../styles/ui-spec.css';

export interface Props {
  title?: string;
  seoTitle?: string;
  description?: string;
  seoDescription?: string;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article';
  locale?: string;
  canonicalURL?: string;
  twitterCard?: 'summary' | 'summary_large_image';
  articlePublishedTime?: string;
  articleModifiedTime?: string;
  articleTags?: string[];
}

const {
  title = 'GameGeek-Saikel',
  seoTitle,
  description,
  seoDescription,
  ogImage = '/og-default.png',
  ogImageAlt,
  ogType = 'website',
  locale,
  canonicalURL,
  twitterCard = 'summary_large_image',
  articlePublishedTime,
  articleModifiedTime,
  articleTags,
} = Astro.props;

const currentLocale = (locale || Astro.currentLocale || 'zh-cn') as Locale;

const resolvedDescription = description || (currentLocale === 'zh-cn'
  ? '游戏极客-Saikel 个人主页 — 技术博客、Unreal Engine 5 插件、游戏开发与 AI 探索'
  : 'GameGeek-Saikel — Tech blog, Unreal Engine 5 plugins, game development & AI exploration');

const pageSeoTitle = seoTitle || title;

const pageSeoDescription = seoDescription || resolvedDescription;

const barePath = stripLocalePrefix(Astro.url.pathname);
const canonical = canonicalURL || new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang={currentLocale} dir={getLocaleDir(currentLocale)} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="google-site-verification" content="txz4dUaOFXMYV8kJqf4vuqyaX1zr49yYR7qckNRzLjM" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="preconnect" href="https://cdn-font.hyperos.mi.com" crossorigin />
    <link rel="stylesheet" href="https://cdn-font.hyperos.mi.com/font/css?family=MiSans:100,200,300,400,450,500,600,650,700,900:Chinese_Simplify,Latin&display=swap" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{pageSeoTitle}</title>
    <meta name="description" content={pageSeoDescription} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageSeoTitle} />
    <meta property="og:description" content={pageSeoDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={ogImageAlt || pageSeoDescription} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={currentLocale === 'zh-cn' ? '游戏极客-Saikel' : 'GameGeek-Saikel'} />
    <meta property="og:locale" content={toOgLocale(currentLocale)} />

    {ogType === 'article' && articlePublishedTime && (
      <meta property="article:published_time" content={articlePublishedTime} />
    )}
    {ogType === 'article' && articleModifiedTime && (
      <meta property="article:modified_time" content={articleModifiedTime} />
    )}
    {ogType === 'article' && articleTags && articleTags.map(tag => (
      <meta property="article:tag" content={tag} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={pageSeoTitle} />
    <meta name="twitter:description" content={pageSeoDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt || pageSeoDescription} />

    <!-- Alternate locales -->
    <link rel="canonical" href={canonical} />
    {supportedLocales.map(loc => (
      <link rel="alternate" hreflang={toHreflangLocale(loc)} href={new URL(getRelativeLocaleUrl(loc, barePath), Astro.site).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/', Astro.site).href} />

    <!-- Favicon -->
    <link rel="shortcut icon" href="https://avatars.githubusercontent.com/u/88531138" type="image/x-icon" />

    <!-- RSS -->
    {locales.map(loc => (
      <link rel="alternate" type="application/rss+xml" title={`Blog RSS (${loc})`} href={loc === 'zh-cn' ? '/blog/rss.xml' : `/${loc}/blog/rss.xml`} />
    ))}

    <!-- 主题同步脚本：在页面渲染前应用主题，防止 FOUC -->
    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('theme');
          var theme = (stored === 'dark' || stored === 'light')
            ? stored
            : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          var root = document.documentElement;
          if (theme === 'light') root.classList.add('light-style');
          root.setAttribute('data-theme', theme);
        } catch(e) {}
      })();
    </script>

    <!-- JSON-LD 结构化数据 -->
    <script type="application/ld+json" set:html={JSON.stringify(ogType === 'article' ? {
      '@context': 'https://schema.org',
      '@type': 'BlogPosting',
      headline: pageSeoTitle,
      description: pageSeoDescription,
      image: ogImage,
      url: canonical,
      datePublished: articlePublishedTime,
      dateModified: articleModifiedTime || articlePublishedTime,
      author: { '@type': 'Person', 'name': 'Saikel', 'url': Astro.site?.href },
    } : {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: currentLocale === 'zh-cn' ? '游戏极客-Saikel' : 'GameGeek-Saikel',
      url: Astro.site?.href,
      description: pageSeoDescription,
      inLanguage: currentLocale,
    })} />

    <ClientRouter />
  </head>
  <body>
    <!-- Layer 2: 希尔伯特曲线分形纹理 -->
    <div class="bg-hilbert" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="hilbert-pattern" width="280" height="280" patternUnits="userSpaceOnUse" patternTransform="rotate(45)">
            <path id="hilbert-path" fill="none" stroke="#242424" stroke-width="7" stroke-linecap="round" stroke-linejoin="round" opacity="0.55" vector-effect="non-scaling-stroke" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#hilbert-pattern)" />
      </svg>
    </div>

    <!-- Gosper 曲线代码块背景 path 定义 + 图片纸张噪点滤镜 -->
    <svg width="0" height="0" aria-hidden="true" class="absolute">
      <defs>
        <path id="gosper-curve" fill="none" stroke="#242424" stroke-width="7"
              stroke-linecap="round" stroke-linejoin="round" opacity="0.55"
              vector-effect="non-scaling-stroke" />
      </defs>
    </svg>

    <Header />
    <main class="page-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  import { initTheme } from '../scripts/theme';
  import { initHilbert } from '../scripts/hilbert';
  import { initCodeBg } from '../scripts/code-bg';
  import { initNavSlider, initLangSlider } from '../scripts/nav-slider';

  // 浏览器语言自动跳转：首次访问检测语言写入 localStorage，
  // 后续无 locale 前缀的页面据此跳转。用户手动切换语言时更新。
  (function() {
    const SUPPORTED = ['zh-cn','en-us','ja-jp','ko-kr','ar-sa','es-es','fr-fr','pt-pt','ru-ru','de-de'];
    const path = window.location.pathname;
    const STORAGE_KEY = 'user-locale';

    // 从当前 URL 提取 locale
    function localeFromPath(p: string): string | null {
      for (const l of SUPPORTED) {
        if (p.startsWith('/' + l + '/') || p === '/' + l) return l;
      }
      return null;
    }

    const currentLocale = localeFromPath(path);

    // 1. 有 locale 前缀的页面：更新 localStorage 记录当前语言偏好
    if (currentLocale) {
      localStorage.setItem(STORAGE_KEY, currentLocale);
      return;
    }

    // 2. 无 locale 前缀的默认页：根据 localStorage 或浏览器语言跳转
    let preferred = localStorage.getItem(STORAGE_KEY);
    if (!preferred) {
      // 首次访问，从浏览器语言推断
      const navLang = (navigator.language || '').toLowerCase();
      preferred = SUPPORTED.includes(navLang) ? navLang : null;
      if (!preferred) preferred = SUPPORTED.find(s => s.startsWith(navLang.split('-')[0])) ?? null;
      if (preferred && preferred !== 'zh-cn') {
        localStorage.setItem(STORAGE_KEY, preferred);
      }
    }

    if (preferred && preferred !== 'zh-cn') {
      const dest = path === '/' ? '/' + preferred + '/' : '/' + preferred + path;
      window.location.replace(dest);
    }
    // zh-cn 用户不跳转，留在默认页
  })();

  function init() {
    initTheme();
    initHilbert();
    initCodeBg();
    initNavSlider();
    initLangSlider();
  }

  // 客户端导航后重新初始化
  document.addEventListener('astro:page-load', init);

  // 导航交换前同步主题，防止闪白
  document.addEventListener('astro:after-swap', () => {
    try {
      var stored = localStorage.getItem('theme');
      var theme = (stored === 'dark' || stored === 'light')
        ? stored
        : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      var root = document.documentElement;
      root.classList.remove('light-style', 'dark-style');
      if (theme === 'light') root.classList.add('light-style');
      root.setAttribute('data-theme', theme);
    } catch(e) {}
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
