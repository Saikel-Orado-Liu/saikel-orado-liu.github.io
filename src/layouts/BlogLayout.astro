---
import BaseLayout from './BaseLayout.astro';
import { useTranslations, toDateLocale } from '../i18n';
import type { Locale } from '../i18n';

interface Props {
  title: string;
  seoTitle?: string;
  description?: string;
  seoDescription?: string;
  locale: Locale;
  date?: Date;
  tags?: string[];
  categories?: string[];
  image?: string;
}

const { title, seoTitle, description, seoDescription, locale, date, tags, categories, image } = Astro.props;
const t = useTranslations(locale);
---

<BaseLayout
  title={title}
  seoTitle={seoTitle}
  description={description}
  seoDescription={seoDescription}
  ogImage={image || '/og-blog.png'}
  ogType="article"
  articlePublishedTime={date?.toISOString()}
  articleTags={tags}
  twitterCard="summary_large_image"
  locale={locale}
>
  <article class="container-narrow blog-article pt-12 pb-24">
    <header class="blog-header mb-12 pb-8 border-b border-[var(--md-sys-color-outline-variant)]">
      <h1 class="text-4xl mb-2 text-on-surface">{title}</h1>
      {date && (
        <time class="block text-sm mb-4 text-on-surface-variant" datetime={date.toISOString()}>
          {t('blog-published')} {date.toLocaleDateString(toDateLocale(locale), { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      <div class="flex flex-wrap gap-2">
        {categories && categories.length > 0 && (
          <div class="flex gap-2 flex-wrap">
            {categories.map(cat => <span class="tag-accent"><span>{cat}</span></span>)}
          </div>
        )}
        {tags && tags.length > 0 && (
          <div class="flex gap-2 flex-wrap">
            {tags.map(tag => <a href={`${locale === 'zh-cn' ? '' : `/${locale}`}/blog/tag/${tag}/`} class="tag"><span>{tag}</span></a>)}
          </div>
        )}
      </div>
    </header>
    <div class="article-content">
      <slot />
    </div>
  </article>
</BaseLayout>


<script>
  import { initLightbox } from '../scripts/lightbox';
  document.addEventListener('astro:page-load', () => initLightbox());
</script>
